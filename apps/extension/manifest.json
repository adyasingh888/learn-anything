{
  "manifest_version": 3,
  "name": "Learn Anything — Capture",
  "version": "0.1.0",
  "description": "Save the current page or selection to a Brain in Learn Anything.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Learn Anything"
  },
  "permissions": ["activeTab", "scripting", "storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  }
}
