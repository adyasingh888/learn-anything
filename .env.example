# Optional — app works fully without these (see docs/FREE_TIER.md)

# Rich tutor + LLM flashcards (OpenAI-compatible)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Higher rate limits (all free to obtain)
# JINA_API_KEY=              # jina.ai/reader — faster URL reading & web search
# SEMANTIC_SCHOLAR_API_KEY=  # semanticscholar.org/product/api
# OPENALEX_API_KEY=          # openalex.org/settings/api

# Local LLM via Ollama (self-hosted / local dev only)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
